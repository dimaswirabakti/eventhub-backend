rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // ============================================
    // HELPER FUNCTIONS
    // ============================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isUnderSize(maxBytes) {
      return request.resource.size < maxBytes;
    }

    function isValidImage() {
      return request.resource.contentType.matches('image/(jpeg|jpg|png|webp|gif)');
    }

    function isValidPdf() {
      return request.resource.contentType == 'application/pdf';
    }

    // ============================================
    // USER AVATARS (logo EO / Company)
    // Path: /users/{firebaseUid}/{fileName}
    // ============================================

    match /users/{userId}/{fileName} {
      // Siapa saja yang sudah login bisa baca avatar
      allow read: if isAuthenticated();

      // Hanya owner yang bisa upload/update. Max 2MB, harus image.
      allow write: if isOwner(userId)
                   && isValidImage()
                   && isUnderSize(2 * 1024 * 1024);

      allow delete: if isOwner(userId);
    }

    // ============================================
    // EVENT FILES (banner & proposal)
    // Path: /events/{eventId}/{fileName}
    //
    // Banner: fileName mulai dengan "banner." → harus image, max 5MB
    // Proposal: fileName == "proposal.pdf" → harus PDF, max 10MB
    //
    // Ownership Event tidak bisa dicek di Storage Rules
    // (tidak ada akses ke PostgreSQL aplikasi ini).
    // Backend SECARA TAMBAHAN validate ownership saat URL dikirim.
    // ============================================

    match /events/{eventId}/{fileName} {
      // Publik bisa baca (untuk display katalog event yang sudah published)
      allow read: if true;

      // Banner: harus image, max 5MB
      allow write: if isAuthenticated()
                   && fileName.matches('banner\\..*')
                   && isValidImage()
                   && isUnderSize(5 * 1024 * 1024);

      // Proposal: harus PDF persis bernama "proposal.pdf", max 10MB
      allow write: if isAuthenticated()
                   && fileName == 'proposal.pdf'
                   && isValidPdf()
                   && isUnderSize(10 * 1024 * 1024);

      // Delete via backend Admin SDK only (bypass rules otomatis)
    }

    // ============================================
    // FALLBACK: Deny semua path lain
    // ============================================
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}