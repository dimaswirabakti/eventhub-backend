generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model User {
  id           String   @id @default(cuid())
  firebaseUid  String   @unique
  email        String   @unique
  name         String
  role         UserRole
  tokenBalance Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

enum UserRole {
  EO
  COMPANY
  ADMIN
}